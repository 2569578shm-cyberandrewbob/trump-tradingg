# Server
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Database (PostgreSQL or Supabase connection string)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/trump_trading

# Redis (queues, cache, rate limiting)
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=change-me-long-random-string
JWT_REFRESH_SECRET=change-me-different-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# AI analysis (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-fable-5

# Firebase Cloud Messaging — path to service account JSON (never commit the file)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Source API keys (leave blank to disable that adapter)
TRUTH_SOCIAL_API_KEY=
NEWS_API_KEY=

# Ingestion
INGEST_POLL_SECONDS_DEFAULT=60
DEDUPE_WINDOW_HOURS=6
DEDUPE_SIMILARITY_THRESHOLD=0.85

# Safeguards
MIN_RELIABILITY_FOR_CRITICAL=80
